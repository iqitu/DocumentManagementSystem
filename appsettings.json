{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "DocumentManagement": {
    "DataDirectory": "%APPDATA%\\DocumentManagementSystem",
    "MaxBackups": 10,
    "SupportedFileTypes": [
      ".docx",
      ".doc", 
      ".pdf",
      ".xlsx",
      ".xls",
      ".txt",
      ".rtf"
    ]
  }
}